{
  "name": "resume-studio",
  "private": true,
  "scripts": {
    "web:install": "pnpm --dir apps/web install",
    "web:dev": "pnpm --dir apps/web dev",
    "web:build": "pnpm --dir apps/web build",
    "api:dev": "cd apps/api && ./mvnw spring-boot:run",
    "api:test": "cd apps/api && ./mvnw test",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:logs": "docker compose -f infra/docker-compose.yml logs -f",
    "infra:config": "docker compose -f infra/docker-compose.yml config"
  }
}
